# Supabase — find these in your Supabase project settings under API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

NEXT_PUBLIC_APP_URL=https://adhder.io

# Anthropic — used by Local Pulse AI post generation
# Get your key at https://console.anthropic.com/settings/api-keys
ANTHROPIC_API_KEY=sk-ant-...

# Local Pulse bot — the Supabase user ID of the @local_pulse bot account
# Create a user via Supabase Auth (email: localpulse@adhder.io) then copy its UUID here
LOCAL_PULSE_BOT_USER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Cron secret — a random string to protect the /api/cron/* endpoints
# Generate with: openssl rand -hex 32
CRON_SECRET=your-random-secret-here

# Upstash Redis — optional but recommended for production rate limiting
# Without these, the app falls back to an in-process rate limiter (fine for dev/staging)
# Create a database at https://console.upstash.com and copy the REST credentials
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token
